SECRET_KEY=replace-with-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

DATABASE_URL=postgresql+asyncpg://postgres:<db-password>@127.0.0.1:5432/employee_directory
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173

DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_POOL_PRE_PING=true

VITE_API_BASE=http://127.0.0.1:8000/api/v1

# Optional: used only by backend/seed.py
SEED_DATABASE_URL=dbname=employee_directory user=postgres host=localhost
SEED_PASSWORD=replace-with-demo-password
